{
    "dialogues": [
        {
            "speakerName": "货车",
            "message": "夕阳把篷车的影子拉得很长。驮兽低头啃着路边的野草，你靠在车旁翻着账本——数字密密麻麻，但你知道，今天的收入刚够买明天的干粮。"
        },
        {
            "speakerName": "货车",
            "message": "七年了。你走过十二个行省，卖过会唱歌的石头、不会碎的镜子、据说能梦见前世的熏香。有些是真的，有些……买家觉得是真的就够了。"
        },
        {
            "speakerName": "货车",
            "message": "合上账本的时候，余光扫到货箱——那里多了一样东西。一封没有邮戳的信，静静躺在麻袋上面，像是专程等着你发现。"
        },
        {
            "speakerName": "主角",
            "message": "“今天的货单里……没这封信啊。”你皱了皱眉，弯腰捡起来。"
        },
        {
            "speakerName": "神秘委托",
            "message": "目标：刺杀帝国国王\n报酬：你的命\n委托人签名："
        },
        {
            "speakerName": "主角",
            "message": "你盯着签名栏，愣在那里。那是你的名字，一字不差。你的笔迹，连那个习惯性的勾都一模一样。“……什么玩笑？”"
        },
        {
            "speakerName": "主角",
            "message": "你翻来覆去看了三遍。纸是普通的纸，墨是普通的墨。但你不记得写过这个。从来没有。"
        },
        {
            "speakerName": "主角",
            "message": "正想把信扔回去，你注意到货箱角落里多了一样东西。一个盒子。"
        },
        {
            "speakerName": "主角",
            "message": "木头的，旧得看不出年代。你打开——里面什么都没有，又好像什么都装得下。摸不到底。"
        },
        {
            "speakerName": "主角",
            "message": "脑子里突然冒出一个念头：放点特别的东西进去。"
        },
        {
            "speakerName": "主角",
            "message": "你在货箱里翻了翻，三样东西被你挑了出来——"
        },
        {
            "speakerName": "主角",
            "message": "一枚锈迹斑斑的骑士徽章，不知道是谁留给你的，也不知道为什么一直留着。"
        },
        {
            "speakerName": "主角",
            "message": "一把通体漆黑的匕首，刀身冰凉，握在手里时总觉得有人在看你。"
        },
        {
            "speakerName": "主角",
            "message": "一条泛着幽光的蓝色水晶项链，摸上去是温的，放在耳边能听见极低的声音。"
        },
        {
            "speakerName": "主角",
            "message": "你要先把哪一样放进去？"
        },
        {
            "speakerName": "主角",
            "message": "你等了很久。什么都没有。"
        },
        {
            "speakerName": "主角",
            "message": "又扔了一枚铜板。还是没有。"
        },
        {
            "speakerName": "主角",
            "message": "盒子像死了一样，沉默着，黑洞洞的开口对着你，什么都不给，也什么都不收。"
        },
        {
            "speakerName": "主角",
            "message": "“……算了，不管了。”"
        },
        {
            "speakerName": "主角",
            "message": "你把盒子扔回货箱，盖上盖子。驮兽叫了一声，像是在催你上路。"
        },
        {
            "speakerName": "主角",
            "message": "你跳上车，扯了扯缰绳。篷车慢慢动起来，土路在轮子底下延展开。"
        },
        {
            "speakerName": "主角",
            "message": "你没再回头。"
        }
    ]
}